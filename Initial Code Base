    "import pandas as pd\n",
    "import re\n",
    "\n",
    "# 1. Load the file\n",
    "sub = pd.read_csv('submission.csv')\n",
    "\n",
    "def validate_submission(df):\n",
    "    errors = 0\n",
    "    print(\"--- 🏁 Starting Submission Validation ---\")\n",
    "\n",
    "    # A. Check Column Names\n",
    "    expected_cols = ['ID', 'Pred']\n",
    "    if list(df.columns) == expected_cols:\n",
    "        print(\"✅ Columns: Correct ('ID', 'Pred')\")\n",
    "    else:\n",
    "        print(f\"❌ Columns: Incorrect. Found {df.columns.tolist()}\")\n",
    "        errors += 1\n",
    "\n",
    "    # B. Check Row Count (For 68 teams, should be 2,278 matchups)\n",
    "    if len(df) == 2278:\n",
    "        print(\"✅ Row Count: Correct (2,278 matchups)\")\n",
    "    else:\n",
    "        print(f\"⚠️ Row Count: {len(df)}. (Expected 2,278 for 68 teams). Check your teams list!\")\n",
    "\n",
    "    # C. Check ID Format (2026_LowID_HighID)\n",
    "    sample_id = df['ID'].iloc[0]\n",
    "    pattern = r'^2026_\\d{4}_\\d{4}$'\n",
    "    if re.match(pattern, sample_id):\n",
    "        # Verify LowID < HighID\n",
    "        parts = sample_id.split('_')\n",
    "        if int(parts[1]) < int(parts[2]):\n",
    "            print(f\"✅ ID Format: Correct (e.g., {sample_id})\")\n",
    "        else:\n",
    "            print(f\"❌ ID Format: Wrong order! {parts[1]} must be smaller than {parts[2]}.\")\n",
    "            errors += 1\n",
    "    else:\n",
    "        print(f\"❌ ID Format: Incorrect pattern. Found {sample_id}\")\n",
    "        errors += 1\n",
    "\n",
    "    # D. Check Probability Range (0.0 to 1.0)\n",
    "    if df['Pred'].min() >= 0 and df['Pred'].max() <= 1:\n",
    "        print(f\"✅ Probabilities: Valid range ({df['Pred'].min():.2f} to {df['Pred'].max():.2f})\")\n",
    "    else:\n",
    "        print(f\"❌ Probabilities: Out of bounds! Found values outside [0, 1].\")\n",
    "        errors += 1\n",
    "\n",
    "    if errors == 0:\n",
    "        print(\"\\n🚀 ALL CLEAR! Your file is ready for the 2026 Leaderboard.\")\n",
    "    else:\n",
    "        print(f\"\\n🛑 Found {errors} errors. Do not submit yet!\")\n",
    "\n",
    "validate_submission(sub)\n"
   ]
