    "# --- STEP 3: PREPARE TRAINING DATA (HISTORICAL DIFFERENCES) ---\n",
    "# We use games since 2015 to train the model on how \"Diffs\" lead to wins\n",
    "train_games = results_df[results_df['Season'] >= 2015].copy()\n",
    "\n",
    "win_rows = train_games[['Season', 'WTeamID', 'LTeamID']].rename(columns={'WTeamID': 'T1', 'LTeamID': 'T2'})\n",
    "win_rows['Result'] = 1\n",
    "loss_rows = train_games[['Season', 'LTeamID', 'WTeamID']].rename(columns={'LTeamID': 'T1', 'WTeamID': 'T2'})\n",
    "loss_rows['Result'] = 0\n",
    "\n",
    "train_df = pd.concat([win_rows, loss_rows])\n",
    "\n",
    "# Merge with stats for both teams\n",
    "train_df = train_df.merge(season_stats, left_on=['Season', 'T1'], right_on=['Season', 'TeamID'])\n",
    "train_df = train_df.merge(season_stats, left_on=['Season', 'T2'], right_on=['Season', 'TeamID'], suffixes=('_T1', '_T2'))\n",
    "\n",
    "# Calculate the Diffs the Random Forest will learn from\n",
    "train_df['Diff_AdjOE'] = train_df['AdjOE_T1'] - train_df['AdjOE_T2']\n",
    "train_df['Diff_AdjDE'] = train_df['AdjDE_T1'] - train_df['AdjDE_T2']\n",
    "train_df['Diff_Tempo'] = train_df['Tempo_T1'] - train_df['Tempo_T2']\n",
    "train_df['Diff_EffMargin'] = (train_df['AdjOE_T1'] - train_df['AdjDE_T1']) - (train_df['AdjOE_T2'] - train_df['AdjDE_T2'])\n"
   ]
