    "# --- PREPARATION: CREATE SEASON_STATS ---\n",
    "\n",
    "#Pre- Code for Execution setting the path\n",
    "path_prefix = '/kaggle/input/competitions/march-machine-learning-mania-2026/'\n",
    "detailed_results = pd.read_csv(f'{path_prefix}MRegularSeasonDetailedResults.csv')\n",
    "\n",
    "# 1. Load the detailed results (needed for efficiency metrics)\n",
    "detailed_results = pd.read_csv(f'{path_prefix}MRegularSeasonDetailedResults.csv')\n",
    "\n",
    "def prepare_season_stats(df):\n",
    "    # Create stats for winners\n",
    "    w_stats = df[['Season', 'WTeamID', 'WScore', 'LScore', 'WFGA', 'WOR', 'WTO', 'WFTA']].copy()\n",
    "    w_stats.columns = ['Season', 'TeamID', 'PointsFor', 'PointsAgainst', 'FGA', 'OR', 'TO', 'FTA']\n",
    "    \n",
    "    # Create stats for losers\n",
    "    l_stats = df[['Season', 'LTeamID', 'LScore', 'WScore', 'LFGA', 'LOR', 'LTO', 'LFTA']].copy()\n",
    "    l_stats.columns = ['Season', 'TeamID', 'PointsFor', 'PointsAgainst', 'FGA', 'OR', 'TO', 'FTA']\n",
    "    \n",
    "    # Combine them to get stats for every team in every game\n",
    "    stats_concat = pd.concat([w_stats, l_stats])\n",
    "    \n",
    "    # Calculate Possessions (Standard NCAA formula)\n",
    "    # Possessions = 0.96 * (FGA - OR + TO + 0.44 * FTA)\n",
    "    stats_concat['Possessions'] = 0.96 * (\n",
    "        stats_concat['FGA'] - stats_concat['OR'] + stats_concat['TO'] + (0.44 * stats_concat['FTA'])\n",
    "    )\n",
    "    \n",
    "    # Aggregate by Season and Team\n",
    "    season_stats = stats_concat.groupby(['Season', 'TeamID']).agg({\n",
    "        'PointsFor': 'sum',\n",
    "        'PointsAgainst': 'sum',\n",
    "        'Possessions': 'sum'\n",
    "    }).reset_index()\n",
    "    \n",
    "    # Calculate efficiency metrics\n",
    "    # AdjOE: Points scored per 100 possessions\n",
    "    # AdjDE: Points allowed per 100 possessions\n",
    "    # Tempo: Average possessions per game (we'll divide by game count)\n",
    "    \n",
    "    games_played = stats_concat.groupby(['Season', 'TeamID']).size().reset_index(name='GameCount')\n",
    "    season_stats = season_stats.merge(games_played, on=['Season', 'TeamID'])\n",
    "    \n",
    "    season_stats['AdjOE'] = (season_stats['PointsFor'] / season_stats['Possessions']) * 100\n",
    "    season_stats['AdjDE'] = (season_stats['PointsAgainst'] / season_stats['Possessions']) * 100\n",
    "    season_stats['Tempo'] = season_stats['Possessions'] / season_stats['GameCount']\n",
    "    \n",
    "    # Keep only the columns your main script uses\n",
    "    return season_stats[['Season', 'TeamID', 'AdjOE', 'AdjDE', 'Tempo']]\n",
    "\n",
    "# Generate the dataframe\n",
    "season_stats = prepare_season_stats(detailed_results)\n",
    "\n",
    "print(\"✅ 'season_stats' prepared successfully.\")\n",
    "print(season_stats.head())"
   ]
